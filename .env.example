# ============================================================
# 大模型 API 密钥（必填）
# ============================================================
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 低成本小模型（可选，不填则复用主模型）
# LLM_SMALL_API_KEY=sk-your-small-model-key
# LLM_SMALL_BASE_URL=https://api.deepseek.com/v1
# LLM_SMALL_MODEL=deepseek-chat

# ============================================================
# 服务端口
# ============================================================
# 后端 API 服务端口
API_SERVER_PORT=8000
# 前端开发服务器端口
FRONTEND_DEV_PORT=5173

# ============================================================
# 数据库地址
# ============================================================
# 向量数据库（Chroma）持久化路径
CHROMA_DB_PATH=./data/chroma_db
# 关系数据库地址（SQLite 本地文件）
DATABASE_URL=sqlite:///./data/travel.db
# Redis 缓存地址（可选）
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# 运行模式
# ============================================================
# Agent 模式: react（自主修正） / classic（固定流程）
TRAVEL_PLANNER_MODE=react
# 缓存开关
TRAVEL_CACHE_ENABLED=true
